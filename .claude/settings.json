{
  "permissions": {
    "autoAllow": [
      "Edit",
      "Write",
      "Bash: cd",
      "Bash: npm"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[hooks] File modified: {{file_path}}'"
          }
        ]
      }
    ]
  }
}
